The SQL being executed was: INSERT INTO `majliss_synced_post` (`wp_post_id`, `title`, `post_content`, `category`, `wp_date`, `space_id`, `sync_status`, `image_url`, `image_file_guid`, `created_at`, `updated_at`) VALUES (19324, 'Spotlight on basic education completion and foundational learning in Africa, 2025: lead for foundational learning', '<p><img loading=\"lazy\" decoding=\"async\" class=\"lazyload_inited size-medium wp-image-19325 aligncenter\" src=\"https://emajlis-info.csefrs.ma/wp-content/uploads/2025/11/Visuel-MajlisCom-2025-2025-11-04T154158.444-700x525.png\" alt=\"\" width=\"700\" height=\"525\" /></p>\n<p style=\"text-align: justify;\">\n<p style=\"text-align: justify;\">Ce rapport examine la répartition des compétences sociales et émotionnelles au sein de la population adulte et leur influence sur les principaux résultats de la vie, au-delà de l&#8217;impact des compétences cognitives mesurées dans l&#8217;enquête, telles que la littératie. Les résultats soulignent l&#8217;importance des compétences sociales et émotionnelles pour la réussite professionnelle et personnelle des adultes.</p>\n<p style=\"text-align: justify;\">Si les compétences cognitives demeurent des déterminants clés des résultats sur le marché du travail, les compétences sociales et émotionnelles contribuent indépendamment à l&#8217;emploi, aux salaires et à la satisfaction professionnelle. Elles sont également positivement corrélées au niveau d&#8217;éducation, à la santé, au bien-être et à la participation civique. De plus, ces compétences varient selon les groupes sociodémographiques, notamment en fonction de l&#8217;âge, du sexe, du niveau d&#8217;éducation des parents et de l&#8217;origine immigrée. S&#8217;appuyant sur ces données, le rapport examine les options politiques visant à promouvoir l&#8217;apprentissage social et émotionnel tout au long de la vie, en soulignant son importance pour soutenir les adultes en tant que travailleurs, apprenants et citoyens actifs.</p>\n<p style=\"text-align: justify;\"><a href=\"https://www.oecd.org/content/dam/oecd/en/publications/reports/2025/10/skills-that-matter-for-success-and-well-being-in-adulthood_10222f2b/6e318286-en.pdf\">https://www.oecd.org/content/dam/oecd/en/publications/reports/2025/10/skills-that-matter-for-success-and-well-being-in-adulthood_10222f2b/6e318286-en.pdf</a></p>', 'L\'Info Doc', '2025-11-04T15:44:20', 22, 2, 'https://emajlis-info.csefrs.ma/wp-content/uploads/2025/11/Visuel-MajlisCom-2025-2025-11-04T154158.444-1.png', '35268855-4c04-485e-bca4-c4b132a1cb28', '2026-04-07 15:26:10', '2026-04-07 15:26:10')
