The SQL being executed was: INSERT INTO `majliss_synced_post` (`wp_post_id`, `title`, `post_content`, `category`, `wp_date`, `space_id`, `sync_status`, `image_url`, `image_file_guid`, `created_at`, `updated_at`) VALUES (19857, 'Vient de paraître –Bulletin électronique de veille documentaire en éducation-formation n°43', '<p><img loading=\"lazy\" decoding=\"async\" class=\"lazyload_inited size-medium wp-image-19858 aligncenter\" src=\"https://emajlis-info.csefrs.ma/wp-content/uploads/2026/02/Visuel-MajlisCom-2025-2026-02-19T125032.229-700x525.png\" alt=\"\" width=\"700\" height=\"525\" srcset=\"https://emajlis-info.csefrs.ma/wp-content/uploads/2026/02/Visuel-MajlisCom-2025-2026-02-19T125032.229-700x525.png 700w, https://emajlis-info.csefrs.ma/wp-content/uploads/2026/02/Visuel-MajlisCom-2025-2026-02-19T125032.229-768x576.png 768w, https://emajlis-info.csefrs.ma/wp-content/uploads/2026/02/Visuel-MajlisCom-2025-2026-02-19T125032.229-370x278.png 370w, https://emajlis-info.csefrs.ma/wp-content/uploads/2026/02/Visuel-MajlisCom-2025-2026-02-19T125032.229-760x570.png 760w, https://emajlis-info.csefrs.ma/wp-content/uploads/2026/02/Visuel-MajlisCom-2025-2026-02-19T125032.229.png 800w\" sizes=\"(max-width: 700px) 100vw, 700px\" /></p>\n<p>Le dernier numéro du bulletin électronique de veille documentaire en éducation-formation vient de paraitre.</p>\n<p>Ce bulletin propose une veille électronique axée sur les domaines de l’éducation et de la formation. Il présente l’actualité éditoriale et informationnelle nationale et internationale, et offre une sélection de ressources documentaires (ouvrages, rapports, revues, articles…).</p>\n<p style=\"text-align: center;\"><a href=\"https://emajlis-info.csefrs.ma/wp-content/uploads/2026/02/Numero-43-Janvier-2026.pdf\">Numero-43-Janvier-2026.pdf</a></p>', 'L\'Info Doc', '2026-02-19T14:50:03', 22, 2, 'https://emajlis-info.csefrs.ma/wp-content/uploads/2026/02/Visuel-MajlisCom-2025-2026-02-19T125032.229.png', '33f564d0-2076-4f13-86e4-7bf4d2c4d140', '2026-04-07 15:26:14', '2026-04-07 15:26:14')
