The SQL being executed was: INSERT INTO `majliss_synced_post` (`wp_post_id`, `title`, `post_content`, `category`, `wp_date`, `space_id`, `sync_status`, `image_url`, `created_at`, `updated_at`) VALUES (8571, 'Chrome : Rouvrir un onglet fermé par erreur  ', '<p><span data-ccp-props=\"{&quot;201341983&quot;:0,&quot;335559739&quot;:0,&quot;335559740&quot;:240}\"> </span></p>\n<p><span data-ccp-props=\"{&quot;201341983&quot;:0,&quot;335551550&quot;:2,&quot;335551620&quot;:2,&quot;335559739&quot;:0,&quot;335559740&quot;:240}\"><img loading=\"lazy\" decoding=\"async\" class=\"lazyload_inited size-medium wp-image-8572 aligncenter\" src=\"https://emajlis-info.csefrs.ma/wp-content/uploads/2022/10/chrome-700x525.jpg\" alt=\"\" width=\"700\" height=\"525\" /></span></p>\n<p><span data-ccp-props=\"{&quot;201341983&quot;:0,&quot;335559739&quot;:0,&quot;335559740&quot;:240}\"> </span></p>\n<p><span data-contrast=\"none\">Vous venez de fermer une page Web par erreur et vous souhaitez la retrouver ? Chrome vous permet facilement de retrouver les onglets récemment fermés.</span><span data-ccp-props=\"{&quot;201341983&quot;:0,&quot;335551550&quot;:6,&quot;335551620&quot;:6,&quot;335559739&quot;:0,&quot;335559740&quot;:240}\"> </span></p>\n<p><span data-ccp-props=\"{&quot;201341983&quot;:0,&quot;335551550&quot;:6,&quot;335551620&quot;:6,&quot;335559739&quot;:0,&quot;335559740&quot;:240}\"> </span></p>\n<ol>\n<li><span data-contrast=\"none\">Dans Chrome, cliquez avec le bouton droit de la souris dans la barre de titre, à droite des onglets déjà ouverts.</span><span data-ccp-props=\"{&quot;134233117&quot;:true,&quot;134233118&quot;:true,&quot;201341983&quot;:0,&quot;335551550&quot;:6,&quot;335551620&quot;:6,&quot;335559739&quot;:160,&quot;335559740&quot;:240}\"> </span></li>\n<li><span data-contrast=\"none\">Cliquez sur </span><b><span data-contrast=\"none\">Rouvrir l&#8217;onglet fermé</span></b><span data-contrast=\"none\">.</span>&nbsp;\n<p><span data-ccp-props=\"{&quot;134233117&quot;:true,&quot;134233118&quot;:true,&quot;201341983&quot;:0,&quot;335551550&quot;:6,&quot;335551620&quot;:6,&quot;335559685&quot;:720,&quot;335559739&quot;:160,&quot;335559740&quot;:240}\"> <img loading=\"lazy\" decoding=\"async\" class=\"lazyload_inited size-medium wp-image-8573 aligncenter\" src=\"https://emajlis-info.csefrs.ma/wp-content/uploads/2022/10/Capture-astuce-chrome-700x276.png\" alt=\"\" width=\"700\" height=\"276\" /></span></li>\n<li><span data-contrast=\"none\">Le dernier onglet fermé est alors rouvert, notez que vous pouvez utiliser le raccourci clavier </span><span data-contrast=\"none\">Ctrl + Maj + T</span><span data-ccp-props=\"{&quot;134233117&quot;:true,&quot;201341983&quot;:0,&quot;335551550&quot;:6,&quot;335551620&quot;:6,&quot;335559739&quot;:240,&quot;335559740&quot;:240}\"> </span></li>\n<li><span data-contrast=\"none\">Répétez l&#8217;opération pour récupérer d&#8217;autres pages fermées précédemment.</span><span data-ccp-props=\"{&quot;134233117&quot;:true,&quot;134233118&quot;:true,&quot;201341983&quot;:0,&quot;335551550&quot;:6,&quot;335551620&quot;:6,&quot;335559739&quot;:160,&quot;335559740&quot;:240}\"> </span></li>\n</ol>', 'L\'Astuce IT', '2022-10-04T09:42:06', 22, 2, '', '2026-04-07 15:25:32', '2026-04-07 15:25:32')
