The SQL being executed was: INSERT INTO `majliss_synced_post` (`wp_post_id`, `title`, `post_content`, `category`, `wp_date`, `space_id`, `sync_status`, `image_url`, `image_file_guid`, `created_at`, `updated_at`) VALUES (19127, 'زيارة وفد من المجلس الأعلى للتربية والتكوين والبحث العلمي لضريح جلالة المغفور له الملك محمد الخامس', '<p><img loading=\"lazy\" decoding=\"async\" class=\"lazyload_inited size-medium wp-image-19128 aligncenter\" src=\"https://emajlis-info.csefrs.ma/wp-content/uploads/2025/10/Visuel-MajlisCom-2025-97-700x525.png\" alt=\"\" width=\"700\" height=\"525\" /></p>\n<p>&nbsp;</p>\n<p style=\"text-align: right;\">بمناسبة الذكرى السابعة العشرون لوفاة جلالة المغفور له الملك الحسن الثاني طيب الله ثراه، قامت السيدة رحمة بورقية رفقة وفد من المجلس الأعلى للتربية والتكوين والبحث العلمي، بزيارة لضريح جلالة الملك الحسن الثاني للترحم على الروحين الطاهرتين للمغفور لهما، الملك محمد الخامس والملك الحسن الثاني</p>', 'L’Actu', '2025-10-02T17:16:13', 22, 2, 'https://emajlis-info.csefrs.ma/wp-content/uploads/2025/10/Visuel-MajlisCom-2025-97-1.png', 'd4582500-9d79-423a-a6e2-27f876ca74f9', '2026-04-07 15:26:08', '2026-04-07 15:26:08')
