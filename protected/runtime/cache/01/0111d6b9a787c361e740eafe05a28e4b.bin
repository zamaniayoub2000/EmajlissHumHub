Run";s:10:"1775211721";s:4:"name";s:55:"E-majlis : plateforme d'information et de collaboration";s:7:"baseUrl";s:29:"https://emajlis-dev.csefrs.ma";s:14:"paginationSize";s:2:"10";s:17:"displayNameFormat";s:38:"{profile.firstname} {profile.lastname}";s:19:"mailerTransportType";s:4:"smtp";s:24:"mailerSystemEmailAddress";s:17:"emajlis@csefrs.ma";s:21:"mailerSystemEmailName";s:19:"Plateforme E-Majlis";s:10:"cacheClass";s:21:"yii\caching\FileCache";s:15:"cacheExpireTime";s:4:"3600";s:15:"defaultLanguage";s:2:"fr";s:7:"useCase";s:5:"other";s:6:"secret";s:36:"13f590a0-a0d5-4e69-9942-0bc332d61431";s:15:"defaultTimeZone";s:17:"Africa/Casablanca";s:35:"humhub\components\InstallationState";s:1:"3";s:29:"useDefaultThemeSecondaryColor";s:1:"0";s:17:"themeSuccessColor";s:7:"#52a11c";s:16:"themeDangerColor";s:7:"#fc4a64";s:17:"themeWarningColor";s:7:"#ffc107";s:24:"useDefaultThemeInfoColor";s:1:"0";s:15:"themeLightColor";s:7:"#e7e7e7";s:24:"useDefaultThemeDarkColor";s:1:"0";s:15:"themeCustomScss";s:22480:":root {
    --brand-orange: #CD853F;
    --brand-dark: #06383B;

    --accent-red: #902727;
    --accent-red-2: #8F2B2B;

    --page-bg: #ffffff;

    /* Spaces cards */
    --card-radius: 16px;
    --card-border: rgba(15, 23, 42, 0.10);
    --card-border-hover: rgba(165, 53, 53, 0.28);

    --card-shadow: 0 10px 30px rgba(0,0,0,0.10);
    --card-shadow-hover: 0 18px 50px rgba(0,0,0,0.16);

    --card-body-bg-1: #f4f4f4;
    --card-body-bg-2: #efefef;

    --title: #121212;
    --muted: rgba(18,18,18,0.68);

    --gap: 20px;

    /* Card sizing */
    --img-h: 200px;
    --body-h: 150px;
    --card-h: calc(var(--img-h) + var(--body-h));

    /* Menu (variables only; no menu styling below) */
    --topbar-bg: #ffffff;
    --topbar-border: rgba(15,23,42,.10);
}


/* ============================================
   PROFILE HEADER
============================================ */
.panel-profile .panel-profile-header {
    background: var(--brand-dark) !important;
    color: #fff !important;
}
.panel-profile .panel-profile-header h1 a { color: #fff !important; }
.panel-profile .panel-profile-header h2.space {
    background: var(--brand-orange) !important;
    color: #fff !important;
}


/* ============================================
   BUTTON COLORS
============================================ */
.btn-primary {
    background: var(--brand-dark) !important;
    border-color: var(--brand-dark) !important;
    color: #fff !important;
}
.btn-primary:hover {
    background: #0b4a52 !important;
    border-color: #0b4a52 !important;
    color: #fff !important;
}


/* ============================================
   MOBILE PROFILE FIX
============================================ */
@media (max-width: 768px) {
    .panel-profile .panel-profile-header .img-profile-data {
        width: 100% !important;
        display: block !important;
    }
    .panel-profile .panel-profile-header .img-profile-data h1,
    .panel-profile .panel-profile-header .img-profile-data h2 {
        margin: 0 !important;
        transform: translateY(-10px) !important;
    }
    .panel-profile .panel-profile-header .img-profile-data h1 a,
    .panel-profile .panel-profile-header .img-profile-data .h1 a {
        font-size: 18px !important;
        padding: 2px 6px !important;
        white-space: normal !important;
        word-break: break-word !important;
    }
    .panel-profile .panel-profile-header .img-profile-data h2.space {
        font-size: 13px !important;
        padding: 2px 6px !important;
    }
}


/* ============================================
   HIDE UNWANTED ELEMENTS
============================================ */
.layout-sidebar-container .panel:has(#activityStream) { display: none !important; }

form.form-search[action="/people"] { display: none !important; }
.panel-body:has(> form.form-search[action="/people"]) {
    padding: 0 !important;
    margin: 0 !important;
    min-height: 0 !important;
}

.panel-profile-controls .followButton,
.panel-profile-controls .unfollowButton { display: none !important; }

.panel-profile .statistics > a:nth-child(1),
.panel-profile .statistics > a:nth-child(2),
.statistics a[data-action-url*="space-membership-list"] { display: none !important; }



/* Remove space icons + buttons */
.container-cards.container-spaces .card.card-space .card-icons,
.container-cards.container-spaces .card.card-space i.fa-users,
.container-cards.container-spaces .card.card-space .fa-users { display: none !important; }
.container-cards.container-spaces .card.card-space .btn { display: none !important; }
.container-cards.container-spaces .card.card-space .space-profile-acronym-1,
.container-cards.container-spaces .card.card-space .space-acronym { display: none !important; }




/* ============================================================
   SPACES GRID — 4 columns
============================================================ */
.container-cards.container-spaces .row {
    margin-left: 0 !important;
    margin-right: 0 !important;
    display: flex !important;
    flex-wrap: wrap !important;
    gap: var(--gap) !important;
    align-items: stretch !important;
}

.container-cards.container-spaces .row > [class*="col-"] {
    float: none !important;
    width: auto !important;
    max-width: none !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    flex: 0 0 calc((100% - (3 * var(--gap))) / 4) !important;
    display: flex !important;
    align-items: stretch !important;
}

@media (max-width: 1200px) {
    .container-cards.container-spaces .row > [class*="col-"] {
        flex: 0 0 calc((100% - var(--gap)) / 2) !important;
    }
}
@media (max-width: 780px) {
    .container-cards.container-spaces .row > [class*="col-"] {
        flex: 0 0 100% !important;
    }
}


/* ============================================================
   SPACES CARDS — FIXED HEIGHT
============================================================ */

/* Outer wrapper */
.container-cards.container-spaces .card.card-space {
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    background: transparent !important;
    border: 0 !important;
    box-shadow: none !important;
    padding: 0 !important;
    overflow: visible !important;
    transform: none !important;
    height: var(--card-h) !important;
    min-height: var(--card-h) !important;
    max-height: var(--card-h) !important;
    display: flex !important;
    flex-direction: column !important;
    position: relative !important;
    transition: none !important;
}

.container-cards.container-spaces .card.card-space:hover {
    transform: none !important;
    box-shadow: none !important;
    border-color: transparent !important;
}

.container-cards.container-spaces .card.card-space:focus-within {
    outline: none !important;
    box-shadow: none !important;
    border-color: transparent !important;
}

/* Inner card panel */
.container-cards.container-spaces .card.card-space .card-panel {
    position: relative !important;
    z-index: 1 !important;
    height: var(--card-h) !important;
    min-height: var(--card-h) !important;
    max-height: var(--card-h) !important;
    display: flex !important;
    flex-direction: column !important;
    overflow: hidden !important;
    margin: 0 !important;
}

/* Cover image */
.container-cards.container-spaces .card.card-space .card-panel > .card-bg-image {
    height: var(--img-h) !important;
    min-height: var(--img-h) !important;
    max-height: var(--img-h) !important;
    width: 100% !important;
    flex: 0 0 var(--img-h) !important;
    background-size: cover !important;
    background-position: center !important;
    background-repeat: no-repeat !important;
    display: block !important;
    margin: 0 !important;
    padding: 0 !important;
    filter: saturate(1.05) contrast(1.02) brightness(0.98) !important;
    transition: transform .22s ease, filter .22s ease !important;
}

/* Hide empty header/footer */
.container-cards.container-spaces .card.card-space .card-panel > .card-header,
.container-cards.container-spaces .card.card-space .card-panel > .card-footer {
    display: none !important;
    height: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    border: 0 !important;
}

/* Body */
.container-cards.container-spaces .card.card-space .card-panel > .card-body {
    background: linear-gradient(180deg, var(--card-body-bg-1) 0%, var(--card-body-bg-2) 100%) !important;
    padding: 14px 16px !important;
    height: var(--body-h) !important;
    min-height: var(--body-h) !important;
    max-height: var(--body-h) !important;
    width: 100% !important;
    flex: 0 0 var(--body-h) !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
    overflow: hidden !important;
    border-top: 1px solid rgba(15, 23, 42, 0.08) !important;
    box-sizing: border-box !important;
}

/* Title */
.container-cards.container-spaces .card.card-space h4,
.container-cards.container-spaces .card.card-space .card-title {
    color: var(--title) !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    margin: 0 0 8px 0 !important;
    line-height: 1.22 !important;
    letter-spacing: 0.2px !important;
    display: -webkit-box !important;
    -webkit-line-clamp: 2 !important;
    -webkit-box-orient: vertical !important;
    overflow: hidden !important;
}

/* Description */
.container-cards.container-spaces .card.card-space p {
    color: var(--muted) !important;
    font-size: 12px !important;
    line-height: 1.5 !important;
    margin: 0 !important;
    display: -webkit-box !important;
    -webkit-line-clamp: 5 !important;
    -webkit-box-orient: vertical !important;
    overflow: hidden !important;
    overflow-wrap: anywhere !important;
    word-break: break-word !important;
}

/* Links */
.container-cards.container-spaces .card.card-space a {
    text-decoration: none !important;
    color: inherit !important;
}




/* ====================================================
   REMOVE GAP BETWEEN #topbar-second AND PAGE CONTENT
==================================================== */

#layout-content {
    padding-top: 0 !important;
    margin-top: 0 !important;
}

#layout-content > .container,
#layout-content > .container-fluid {
    padding-top: 0 !important;
    margin-top: 0 !important;
}


/* ============================================================
   FILTERS
============================================================ */

.race-spaces-page #race-filters .panel.panel-default {
    border-radius: 16px !important;
    overflow: hidden !important;
}

.race-spaces-page #race-filters .panel-heading {
    padding: 10px 14px !important;
    font-size: 14px !important;
    line-height: 1.2 !important;
}

.race-spaces-page #race-filters .panel-body {
    padding: 12px 14px 14px !important;
}

.race-spaces-page #race-filters .panel-body .row {
    display: flex !important;
    flex-wrap: wrap !important;
    align-items: center !important;
    gap: 10px !important;
    margin: 0 !important;
}

.race-spaces-page #race-filters .panel-body .row > [class*="col-"]:first-child {
    display: none !important;
}

.race-spaces-page #race-filters .panel-body .row > [class*="col-"] {
    float: none !important;
    padding: 0 !important;
    margin: 0 !important;
    width: auto !important;
    max-width: none !important;
    flex: 1 1 calc((100% - 20px) / 3) !important;
    min-width: 220px !important;
}

.race-spaces-page #race-filters input[type="text"],
.race-spaces-page #race-filters input[type="search"],
.race-spaces-page #race-filters .form-control,
.race-spaces-page #race-filters select {
    height: 40px !important;
    border-radius: 12px !important;
    border: 1px solid rgba(15,23,42,.12) !important;
    background: rgba(255,255,255,.92) !important;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.9) !important;
    font-weight: 650 !important;
}

.race-spaces-page #race-filters .form-group {
    margin: 0 !important;
}

.race-spaces-page #race-filters label {
    font-size: 12px !important;
    font-weight: 850 !important;
    color: rgba(17,24,39,.70) !important;
    margin: 0 0 6px 2px !important;
}

.race-spaces-page #race-filters a[href*="reset"],
.race-spaces-page #race-filters a:has(.fa-times),
.race-spaces-page #race-filters a:has(.fa-refresh) {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    height: 36px !important;
    padding: 0 12px !important;
    border-radius: 12px !important;
    border: 1px solid rgba(165,53,53,.18) !important;
    background: rgba(165,53,53,.06) !important;
    color: rgba(122,31,31,.92) !important;
    font-weight: 850 !important;
    text-decoration: none !important;
    margin-top: 10px !important;
}

@media (max-width: 900px) {
    .race-spaces-page #race-filters .panel-body .row > [class*="col-"] {
        flex: 1 1 100% !important;
        min-width: 0 !important;
    }
}




/* ── Space card fade-in animation ── */
.container-cards.container-spaces .card.card-space .tc-space-card.card-panel {
    animation: cardFadeIn 0.6s cubic-bezier(0.4,0,0.2,1) backwards !important;
}


@keyframes cardFadeIn {
  from { opacity:0; transform:translateY(20px) scale(0.98); }
  to   { opacity:1; transform:translateY(0) scale(1); }
}






.tc-spaces-panel {
    display: none !important;
}





/* Make top menu icons red */
#top-menu-nav i.fa,
#top-menu-nav .fa,
#top-menu-nav i {
    color: #902727 !important;
}




#topbar-second .container {
    display: flex !important;
    justify-content: center !important;
    position: relative;
}

#topbar-second .search {
    position: absolute;
    left: 0;
}



.container-people .panel.panel-default > .panel-heading {
    display: none !important;
}     


/* Remove the "Guides d'utilisation" / Tour getting-started panel */
#getting-started-panel {
  display: none !important;
}


/* Panel titles styling */
.panel-heading {
    background-color: #902727 !important;
    color: #ffffff !important;
}

/* Ensure text and icons inside the title stay white */
.panel-heading * {
    color: #ffffff !important;
}




#topbar-first  { border-bottom: none !important; }
#topbar-second { border-bottom: 3px solid #902727 !important; }








/* ============================================================
   HumHub TOP MENU — Icon LEFT of text + raise ALL labels
   Works even when labels are plain text (no span/#text)
   ============================================================ */

/* 0) If HumHub uses <br> to stack icon/text, disable it */
#top-menu-nav br { display: none !important; }

/* 1) Horizontal layout for ALL top menu links */
#top-menu-nav > li.nav-item > a.nav-link,
#top-menu-nav > li.nav-item.top-menu-item > a.nav-link {
  display: inline-flex !important;
  flex-direction: row !important;
  align-items: center !important;
  justify-content: center !important;

  height: 50px !important;
  padding: 0 14px !important;
  white-space: nowrap !important;

  line-height: 1 !important;
  position: relative !important;
  top: -5px !important;            /* <-- THIS raises icon + text for ALL items */
}

/* 2) Normalize children */
#top-menu-nav > li.nav-item > a.nav-link > *,
#top-menu-nav > li.nav-item.top-menu-item > a.nav-link > * {
  display: inline-flex !important;
  align-items: center !important;
  margin: 0 !important;
  padding: 0 !important;
  line-height: 1 !important;
}

/* 3) Icon spacing */
#top-menu-nav > li.nav-item > a.nav-link > i,
#top-menu-nav > li.nav-item.top-menu-item > a.nav-link > i {
  margin-right: 8px !important;
}

/* 4) If there IS a wrapped label (#text/span), keep it aligned too */
#top-menu-nav > li.nav-item > a.nav-link #text,
#top-menu-nav > li.nav-item > a.nav-link span {
  line-height: 1 !important;
}

/* 5) Dropdown caret alignment */
#top-menu-nav .dropdown-toggle::after,
#top-menu-nav .caret {
  margin-left: 6px !important;
  position: relative !important;
  top: 1px !important;
}
/* Fine-tune: move icons slightly DOWN */
#top-menu-nav > li.nav-item > a.nav-link > i,
#top-menu-nav > li.nav-item.top-menu-item > a.nav-link > i {
    position: relative !important;
    top: 4px !important;
}






























/* ============================================================
   HumHub TOP MENU — icon LEFT of text + perfect underline alignment
   (No moving the <a> itself, so hover/active red line stays aligned)
   ============================================================ */

/* 0) If HumHub uses <br> to stack icon/text, disable it */
#top-menu-nav br { display: none !important; }

/* 1) Horizontal layout for ALL top menu links */
#top-menu-nav > li.nav-item > a.nav-link,
#top-menu-nav > li.nav-item.top-menu-item > a.nav-link {
  display: inline-flex !important;
  flex-direction: row !important;
  align-items: center !important;
  justify-content: center !important;

  height: 50px !important;

  /* This is the trick: more bottom padding pushes content UP
     while the link box (and underline) stays at the same place. */
  padding: 0 14px 8px 14px !important;

  white-space: nowrap !important;
  line-height: 1 !important;

  position: relative !important;
  top: 0 !important; /* IMPORTANT: keep underline aligned */
}

/* 2) Normalize children */
#top-menu-nav > li.nav-item > a.nav-link > *,
#top-menu-nav > li.nav-item.top-menu-item > a.nav-link > * {
  display: inline-flex !important;
  align-items: center !important;
  margin: 0 !important;
  padding: 0 !important;
  line-height: 1 !important;
}

/* 3) Icon spacing + move icons DOWN (applies to all icons, including dropdown) */
#top-menu-nav > li.nav-item > a.nav-link i,
#top-menu-nav > li.nav-item.top-menu-item > a.nav-link i {
  margin-right: 8px !important;
  position: relative !important;
  top: 3px !important;   /* <-- change this to push icons more down */
}

/* 4) Keep wrapped labels aligned if present */
#top-menu-nav > li.nav-item > a.nav-link #text,
#top-menu-nav > li.nav-item > a.nav-link span {
  line-height: 1 !important;
}

/* 5) Dropdown caret alignment */
#top-menu-nav .dropdown-toggle::after,
#top-menu-nav .caret {
  margin-left: 6px !important;
  position: relative !important;
  top: 1px !important;
}

/* Push MES ESPACES content slightly down without moving the link */
#top-menu-nav > li:first-child > a.nav-link > * {
    position: relative !important;
    top: 4px !important;
}



.container-cards.container-spaces .tc-top .tc-avatar {
  visibility: hidden !important;
  opacity: 0 !important;
  width: 0 !important;
  height: 0 !important;
  margin: 0 !important;
  padding: 0 !important;
  overflow: hidden !important;
  pointer-events: none !important;
}




