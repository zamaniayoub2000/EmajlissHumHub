}


:root {
    --hh-ct-top-menu-text-color: #902727 !important;
}
.container-cards.container-spaces .card.card-space p {
    color: #902727 !important;
}
/*
.tc-space-card .tc-title {
    color: #902727 !important;
}  */



:root {
    --hh-ct-top-menu-text-color: #902727!important;

    --hh-ct-top-menu-active-color: #000000 !important;

    --hh-ct-top-menu-active-border-color: #000000 !important;

    --hh-ct-top-menu-active-bg: #000000 !important;
}



#topbar-first .nav > li > a,
#topbar-first .nav > li > a:hover,
#topbar-first .nav > li > a:focus,
#topbar-first .nav > li > a:active,
#topbar-first .nav > li.active > a,
#topbar-first .nav > li > a.active {
    background: transparent !important;
    background-color: transparent !important;
    box-shadow: none !important;
}

#topbar-first .nav > li > a,
#topbar-first .nav > li > a.active {
    color: #ffffff !important;
}

#topbar-first .nav > li > a i,
#topbar-first .nav > li > a.active i {
    color: #ffffff !important;
}

#top-menu-nav > li > a.nav-link.active,
#top-menu-nav > li.active > a {
    border-bottom: 3px solid #902727 !important;
    color: #ffffff !important;
}

#top-menu-nav i.fa, 
#top-menu-nav .fa, 
#top-menu-nav i {
    color: #ab8282 !important;
}

body.hh-ct-menu-style-background .list-group-item.active,
body.hh-ct-menu-style-background .list-group-item.active:hover,
body.hh-ct-menu-style-background .list-group-item.active:focus {
    background-color: #dbdbdb !important;
    color: #000000 !important;
    border-left: none !important;
}

#contentForm,
#contentFormBody,
[data-action-component="content.form.CreateForm"] {
    display: none !important;
}
#wall-stream-filter-nav .wall-stream-filter-body .filter-root.container > .row > div.filter-panel.col:first-of-type {
    display: none !important;
