";s:6:"active";i:1;}s:11:"header_html";a:2:{s:5:"value";s:0:"";s:6:"active";i:1;}s:10:"custom_css";a:2:{s:5:"value";s:6741:"/* =========================
   THEME BLANC + BORDEAUX
========================= */

:root {
  --brand-primary: #923436;
  --brand-gradient: #923436;
  --brand-white: #ffffff;
}


/* =========================
   HEADER PROFIL
========================= */
.panel-profile .panel-profile-header {
  background: var(--brand-gradient) !important;
  color: #ffffff !important;
}

.panel-profile .panel-profile-header h1 a,
.panel-profile .panel-profile-header h2.space {
  color: #ffffff !important;
}


/* =========================
   BOUTONS
========================= */
.btn-primary {
  background: #ffffff !important;
  border: 1px solid var(--brand-primary) !important;
  color: var(--brand-primary) !important;
  font-weight: 600;
}

.btn-primary:hover {
  background: var(--brand-gradient) !important;
  color: #ffffff !important;
  border-color: transparent !important;
}


/* =========================
   MENU TOP
========================= */
#topbar-second {
  border-bottom: 3px solid var(--brand-primary) !important;
}

#top-menu-nav i,
#top-menu-nav .fa {
    font-size: 20px !important;
    margin-bottom: 0px !important;
    display: none;
}

#top-menu-nav > li > a.nav-link.active {
  border-bottom: 3px solid var(--brand-primary) !important;
  color: var(--brand-primary) !important;
}


/* =========================
   TITRES PANELS
========================= */
.panel-heading {
  background: var(--brand-gradient) !important;
  color: #ffffff !important;
}

.panel-heading * {
  color: #ffffff !important;
}


/* =========================
   CARTES ESPACES
========================= */
.container-cards.container-spaces .card.card-space .card-body {
  background: linear-gradient(180deg, #ffffff 0%, #f8f4f6 100%) !important;
}

.container-cards.container-spaces .card.card-space p {
  color: var(--brand-primary) !important;
}


/* =========================
   EFFET HOVER CARTES
========================= */
.container-cards.container-spaces .card.card-space .card-bg-image {
  transition: transform 0.3s ease;
}

.container-cards.container-spaces .card.card-space:hover .card-bg-image {
  transform: scale(1.05);
}



/* ========================================
   FIX MENU ACTIVE + MOBILE (SAFE PATCH)
   N'altère PAS ton header existant
======================================== */


/* =========================
   MENU ACTIF = BLANC
========================= */
#top-menu-nav > .top-menu-item.active > .nav-link,
#top-menu-nav > .top-menu-item > .nav-link.active {
    background: #ffffff !important;
    color: #923436;
    border-radius: 10px !important;
}

/* icône active */
#top-menu-nav > .top-menu-item.active > .nav-link i,
#top-menu-nav > .top-menu-item > .nav-link.active i {
    color: #923436;
}


/* =========================
   MOBILE FIX
========================= */
@media (max-width: 768px) {

    /* garde ton design mais améliore spacing */
    #top-menu-nav {
        display: flex !important;
        justify-content: space-around !important;
        width: 100%;
    }

    /* améliore lisibilité des icônes */
    #top-menu-nav > .top-menu-item > .nav-link {
        padding: 8px 6px !important;
        margin: 4px 2px !important;
        border-radius: 8px !important;
    }

    /* icônes plus visibles */
    #top-menu-nav > .top-menu-item > .nav-link i {
        font-size: 17px !important;
    }

    /* actif mobile */
    #top-menu-nav > .top-menu-item.active > .nav-link {
        background: #ffffff !important;
        color: #923436;
    }

    /* footer responsive */
    footer,
    .footer,
    #footer {
        text-align: center !important;
        padding: 12px 10px !important;
        font-size: 12px !important;
    }

    footer a {
        display: block;
        margin: 4px 0;
    }
}

/* ========================================
   HIDE ELEMENTS - HUMHUB CLEAN
======================================== */

/* Sidebar activity */
.layout-sidebar-container .panel:has(#activityStream) {
  display: none !important;
}

/* Recherche people */
form.form-search[action="/people"] {
  display: none !important;
}

/* Boutons follow/unfollow */
.panel-profile-controls .followButton,
.panel-profile-controls .unfollowButton {
  display: none !important;
}

/* Stats profil */
.panel-profile .statistics > a:nth-child(1),
.panel-profile .statistics > a:nth-child(2),
.statistics a[data-action-url*="space-membership-list"] {
  display: none !important;
}

/* Icons + boutons spaces */
.container-cards.container-spaces .card.card-space .card-icons,
.container-cards.container-spaces .card.card-space i.fa-users,
.container-cards.container-spaces .card.card-space .fa-users,
.container-cards.container-spaces .card.card-space .btn,
.container-cards.container-spaces .card.card-space .space-profile-acronym-1,
.container-cards.container-spaces .card.card-space .space-acronym {
  display: none !important;
}

/* Header/footer vides des cards */
.container-cards.container-spaces .card.card-space .card-header,
.container-cards.container-spaces .card.card-space .card-footer {
  display: none !important;
}

/* Panel spaces custom */
.tc-spaces-panel {
  display: none !important;
}

/* Header liste people */
.container-people .panel.panel-default > .panel-heading {
  display: none !important;
}

/* Getting started */
#getting-started-panel {
  display: none !important;
}

/* Avatar spaces */
.container-cards.container-spaces .tc-top .tc-avatar {
  display: none !important;
}

/* Carte espace spécifique (actualite) */
.container-cards.container-spaces .card.card-space:has(a[href*="/s/actualite"]) {
  display: none !important;
}

/* Photo profil dans espace */
.space-layout-container .profile-user-photo-container {
  display: none !important;
}

/* Users spécifiques */
.tc-people-card[data-user-guid="021b5387-274c-47d6-9dc3-9981639492ae"],
.card.card-people:has(.tc-people-card[data-user-guid="b11d832d-050c-4636-9c13-f1c8b8f3e235"]),
.card.card-people:has(.tc-people-card[data-user-guid="d8ca18e3-be86-40ca-922a-7c21b5c15064"]),
.card.card-people:has(.tc-people-card[data-user-guid="be37890a-f5f2-47e4-9ad0-5e3ddf0619ed"]),
.card.card-people:has(.tc-people-card[data-user-guid="021b5387-274c-47d6-9dc3-9981639492ae"]) {
  display: none !important;
}

/* FORMULAIRE POST ⚠️ */
#contentForm,
#contentFormBody,
[data-action-component="content.form.CreateForm"] {
  display: none !important;
}

/* FILTRE WALL */
#wall-stream-filter-nav .filter-panel.col:first-of-type {
  display: none !important;
}
